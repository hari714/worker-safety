



# Database (SQLite - local file, no server needed)
DATABASE_URL=sqlite:///safety_db.sqlite

# Email (replace with your Gmail App Password)
SENDER_EMAIL=your.email@gmail.com
SENDER_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Model Paths
PPE_MODEL_PATH=models/ppe_detection_best.pt
FACE_EMBEDDING_DIR=worker_embeddings

# Camera Settings
CAMERA_ID=0
VIDEO_FPS=30
FRAME_WIDTH=1280
FRAME_HEIGHT=720

# Detection Thresholds
PPE_CONFIDENCE_THRESHOLD=0.5
FACE_CONFIDENCE_THRESHOLD=0.6
SIMILARITY_THRESHOLD=0.6

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/safety_system.log
